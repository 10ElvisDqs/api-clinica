APP_NAME=ClinicaNuestraSeñoraDelRosario
APP_ENV=production
# APP_KEY se genera automáticamente en el primer docker-compose up
APP_KEY=
APP_DEBUG=false
APP_URL=http://192.168.100.9:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Base de datos — Docker (valores del docker-compose.yml)
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=pruevabdcitasmedicas
DB_USERNAME=admin
DB_PASSWORD=admin123

# ─────────────────────────────────────────────
# Base de datos — Desarrollo local (sin Docker)
# Descomenta estas líneas y comenta las de arriba
# ─────────────────────────────────────────────
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=tu_password_mysql

# ─────────────────────────────────────────────
# JWT — se genera automáticamente en el primer docker-compose up
# ─────────────────────────────────────────────
JWT_SECRET=

# ─────────────────────────────────────────────
# Stripe — reemplaza con tus claves reales si usas pagos
# ─────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
